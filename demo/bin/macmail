#!/usr/bin/env bash
# Mock macmail for the demo GIF (see ../demo.tape). The inbox tells a wholly
# INVENTED story — 서하람, a freelance illustrator who maintains the fictional
# open-source hangul font dalgrim/bomnun — with fictional people, publishers,
# repos, and .example domains throughout. Nothing here derives from real mail.
# Rendering matches macmail: date-first aligned columns, account + Gmail-label
# columns, bright palette, dotted-underline OSC 8 link, yellow DRY-RUN.
# On PATH via demo/bin during `vhs demo/demo.tape`.
set -euo pipefail

Y=$'\033[93m'  # id — bright yellow
C=$'\033[96m'  # sender — bright cyan
B=$'\033[1m'   # subject — bold
G=$'\033[92m'  # date — bright green
M=$'\033[95m'  # account — bright magenta
L=$'\033[94m'  # mailbox label — bright blue
D=$'\033[90m'  # secondary — gray
R=$'\033[0m'

# Clickable link affordance: OSC 8 hyperlink + dotted underline in soft blue,
# exactly as lib/links.ts + lib/color.ts emit.
link() { # url text
  printf '\033]8;;%s\a\033[4:4;38;5;110m%s\033[24;39m\033]8;;\a' "$1" "$2"
}

# Fields are pre-padded to display width (Korean = 2 cols) so the ANSI codes
# (zero-width in a terminal) don't throw the columns off.
row() { # date account mailbox sender subject id
  printf '%s%s%s  %s%s%s  %s%s%s  %s%s%s  %s%s%s  %s%s%s\n' \
    "$G" "$1" "$R" "$M" "$2" "$R" "$L" "$3" "$R" "$C" "$4" "$R" "$B" "$5" "$R" "$Y" "$6" "$R"
}

case "${1:-}" in
  triage)
    row "2026-07-05 09:41" "studio  " "work/의뢰 " "윤보라       " "『고래 정원』 표지 시안 잘 받았어요         " 402198
    row "2026-07-05 09:12" "personal" "dev/bomnun" "GitGureum    " "[dalgrim/bomnun] 겹낫표 커닝 수정 ($(link https://github.example/dalgrim/bomnun/pull/12 'PR #12'))  " 402173
    row "2026-07-05 08:36" "personal" "INBOX     " "엄마         " "복숭아 한 박스 부쳤다, 냉장고에 바로 넣어라 " 402141
    row "2026-07-05 07:58" "studio  " "work/문의 " "Noa Lindqvist" "Album cover inquiry — 'Paper Tides' EP      " 402118
    ;;
  search)
    # Korean query — non-ASCII decoding + width-aware alignment
    row "2026-07-05 09:41" "studio  " "work/의뢰 " "윤보라       " "『고래 정원』 표지 시안 잘 받았어요         " 402198
    row "2026-07-02 14:07" "studio  " "work/의뢰 " "윤보라       " "『고래 정원』 본문 삽화 12컷 최종 확인      " 401562
    printf '%s(showing 2 of 34 — narrow filters if too many)%s\n' "$D" "$R"
    ;;
  read)
    printf '%sFrom:%s %s윤보라 <bora@supbi.example>%s\n' "$D" "$R" "$C" "$R"
    printf '%sTo:%s haram@mulgyeol.example\n' "$D" "$R"
    printf '%sDate:%s %s2026-07-05 09:41%s\n' "$D" "$R" "$G" "$R"
    printf '%sSubject:%s %s『고래 정원』 표지 시안 잘 받았어요%s\n' "$D" "$R" "$B" "$R"
    printf '\n하람 님, 고래 등 위에 뜬 달 보고 편집부가 다 같이 한참 감탄했어요 — 이대로 인쇄 넘길게요, 고생 많으셨어요!\n'
    ;;
  mark)
    printf '%sDRY-RUN:%s would mark message 402198 (studio/INBOX) as read\n' "$Y" "$R"
    ;;
  *)
    echo "macmail: (demo mock) unhandled command: ${*:-}" >&2
    exit 1
    ;;
esac
