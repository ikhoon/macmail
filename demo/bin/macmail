#!/usr/bin/env bash
# Mock macmail for the demo GIF (see ../demo.tape). Prints fictional output with
# the real rendering baked in — date-first aligned columns (readable dates),
# account + Gmail-label (mailbox) columns, compact sender names, bright colors,
# dotted-underline OSC 8 links on PR refs, yellow DRY-RUN — so the recording
# matches what macmail actually prints. Never touches ~/Library/Mail. On PATH
# via demo/bin during `vhs demo/demo.tape` so it shadows the real binary.
set -euo pipefail

Y=$'\033[93m'  # id — bright yellow
C=$'\033[96m'  # sender — bright cyan
B=$'\033[1m'   # subject — bold
G=$'\033[92m'  # date — bright green
M=$'\033[95m'  # account — bright magenta
L=$'\033[94m'  # mailbox label — bright blue
D=$'\033[90m'  # secondary — gray
R=$'\033[0m'

# Clickable link affordance: OSC 8 hyperlink + dotted underline in soft blue,
# exactly as lib/links.ts + lib/color.ts emit.
link() { # url text
  printf '\033]8;;%s\a\033[4:4;38;5;110m%s\033[24;39m\033]8;;\a' "$1" "$2"
}

# Pad each field to a fixed width first, then wrap it in color, so the ANSI
# codes (zero-width in a terminal) don't throw the columns off.
row() { # date account mailbox sender(pre-padded) subject(pre-padded) id
  printf '%s%s%s  %s%-8s%s  %s%-10s%s  %s%s%s  %s%s%s  %s%s%s
' \
    "$G" "$1" "$R" "$M" "$2" "$R" "$L" "$3" "$R" "$C" "$4" "$R" "$B" "$5" "$R" "$Y" "$6" "$R"
}

case "${1:-}" in
  triage)
    row "2026-07-06 09:12" "Personal" "G/github"   "Copilot  " "[ikhoon/macrec] Realtime engine ($(link https://github.com/ikhoon/macrec/pull/19 'PR #19'))          " 2232339
    row "2026-07-06 09:01" "LINE"     "SNYK"       "Snyk     " "[snyk] Vulnerability alert for centraldogma       " 2232336
    row "2026-07-06 08:45" "Personal" "G/shopping" "컬리     " "[컬리] 고객님의 주문이 정상적으로 접수되었습니다. " 2232321
    row "2026-07-06 08:20" "Personal" "INBOX"      "삼성전자 " "삼성닷컴 주문완료                                 " 2232301
    ;;
  search)
    # Korean query — non-ASCII decoding + width-aware alignment
    row "2026-07-05 18:22" "Personal" "G/team"     "김영희   " "팀 워크숍 초대장 (7/18)                           " 2231310
    row "2026-07-01 12:33" "Personal" "G/shopping" "CJ더마켓 " "[CJ THE MARKET] 주문해주셔서 감사합니다.          " 2226885
    printf '%s(showing 2 of 692 — narrow filters if too many)%s
' "$D" "$R"
    ;;
  read)
    printf '%sFrom:%s %s김영희 <yhkim@company.com>%s\n' "$D" "$R" "$C" "$R"
    printf '%sTo:%s you@company.com\n' "$D" "$R"
    printf '%sDate:%s %s2026-07-05 18:22%s\n' "$D" "$R" "$G" "$R"
    printf '%sSubject:%s %s팀 워크숍 초대장 (7/18)%s\n' "$D" "$R" "$B" "$R"
    printf '\n7/18(금) 오후 2시, 3층 라운지에서 하반기 워크숍이 열립니다. 참석 여부를 알려주세요!\n'
    ;;
  mark)
    printf '%sDRY-RUN:%s would mark message 2232339 (Personal/INBOX) as read\n' "$Y" "$R"
    ;;
  *)
    echo "macmail: (demo mock) unhandled command: ${*:-}" >&2
    exit 1
    ;;
esac
